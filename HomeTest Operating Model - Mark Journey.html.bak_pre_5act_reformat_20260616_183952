  .dashboard{background:linear-gradient(135deg,#001a4d,var(--nhs-dark));border-radius:16px;padding:28px 30px 22px;color:#fff;margin:46px 0 0;box-shadow:0 14px 34px rgba(0,26,77,0.32);}
  .dashboard-eyebrow{font-size:10px;font-weight:800;letter-spacing:2px;color:var(--amber);text-transform:uppercase;margin-bottom:6px;}
  .dashboard-title{font-size:18px;font-weight:900;color:#fff;margin-bottom:18px;letter-spacing:-0.3px;}
