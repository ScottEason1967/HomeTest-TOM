  .hero-text{flex:1;min-width:300px;}
  .hero-eyebrow{font-size:11px;font-weight:800;letter-spacing:2px;text-transform:uppercase;color:var(--amber-deep);margin-bottom:10px;}
  .hero-title{font-size:36px;font-weight:900;color:var(--nhs-dark);letter-spacing:-0.8px;line-height:1.08;margin-bottom:12px;}
  .hero-sub{font-size:14.5px;color:var(--text-sec);line-height:1.6;max-width:680px;}
  .hero-source{margin-top:12px;font-size:12px;color:var(--text-muted);font-style:italic;}

