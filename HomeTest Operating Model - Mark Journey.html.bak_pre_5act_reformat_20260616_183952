  .ribbon-num{font-size:22px;font-weight:900;color:var(--nhs-blue);line-height:1;}
  .ribbon-label{font-size:11px;font-weight:800;letter-spacing:1px;text-transform:uppercase;color:var(--text-sec);margin-top:6px;}

