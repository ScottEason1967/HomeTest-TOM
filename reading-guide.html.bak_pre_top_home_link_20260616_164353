<!DOCTYPE html>
<html lang="en-GB">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>How to read this model — HomeTest Operating Model</title>
<style>
:root {
  --nhs-dark:#003087; --nhs-blue:#005EB8; --nhs-green:#006747; --nhs-pink:#AE2573;
  --amber:#FFB91D; --amber-deep:#C9A227; --warm-cream:#FFF9EC;
  --text:#212B32; --text-sec:#4C6272; --text-muted:#7E8B97;
  --border-lt:#ebeef1; --card:#ffffff; --bg:#f8fafc; --pale-blue:#E8F1F6; --pale-blue-bd:#B5D4E5;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Segoe UI',-apple-system,BlinkMacSystemFont,Helvetica,Arial,sans-serif;
     background:linear-gradient(180deg,var(--nhs-blue) 0%,#003087 100%);background-attachment:fixed;
     color:var(--text);line-height:1.55;-webkit-font-smoothing:antialiased;min-height:100vh;}
.page{max-width:1180px;margin:0 auto;padding:36px 28px 56px;}
.card{background:#fff;border-radius:18px;box-shadow:0 14px 40px rgba(0,48,135,0.22);padding:48px 52px 44px;}

/* Draft banner */
.draft-banner{background:var(--warm-cream);border:1.5px solid var(--amber);border-radius:10px;padding:9px 16px;margin-bottom:18px;font-size:11.5px;color:var(--amber-deep);font-weight:700;letter-spacing:0.5px;}
.draft-banner strong{color:#9A6700;}

.eyebrow{font-size:11px;font-weight:800;letter-spacing:2.4px;color:var(--amber-deep);text-transform:uppercase;margin-bottom:14px;}
.h-title{font-size:54px;font-weight:900;color:var(--nhs-dark);letter-spacing:-1.6px;line-height:1.0;margin-bottom:18px;}
.h-sub{font-size:18px;color:var(--text-sec);line-height:1.65;max-width:820px;margin-bottom:20px;}
.h-sub strong{color:var(--text);font-weight:700;}

.amber-rule{width:72px;height:4px;background:var(--amber);border-radius:2px;margin-bottom:18px;}

.section{margin-top:48px;}
.section-eyebrow{font-size:10.5px;font-weight:800;letter-spacing:1.8px;color:var(--amber-deep);text-transform:uppercase;margin-bottom:8px;}
.section-h{font-size:28px;font-weight:900;color:var(--nhs-dark);letter-spacing:-0.6px;line-height:1.1;margin-bottom:12px;}
.section-intro{font-size:14.5px;color:var(--text-sec);line-height:1.7;max-width:840px;margin-bottom:22px;}
.section-intro strong{color:var(--text);font-weight:700;}

/* ===== Future State Blueprint three-block (Peter and Jane) ===== */
.cfc-block{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-top:8px;}
.cfc-tile{background:#F4F8FC;border:1px solid #d6e2ef;border-radius:12px;padding:20px 22px;display:flex;flex-direction:column;}
.cfc-tile.cfc-is{background:#EAF1F8;border-color:var(--pale-blue-bd);}
.cfc-tile.cfc-why{background:#FFF9EC;border-color:#F0DCA0;}
.cfc-tile-num{font-size:11px;font-weight:800;letter-spacing:1.6px;color:var(--text-muted);text-transform:uppercase;margin-bottom:10px;}
.cfc-tile.cfc-is .cfc-tile-num{color:var(--nhs-blue);}
.cfc-tile.cfc-why .cfc-tile-num{color:var(--amber-deep);}
.cfc-tile-h{font-size:15.5px;font-weight:800;color:var(--nhs-dark);letter-spacing:-0.3px;margin-bottom:8px;line-height:1.25;}
.cfc-tile-body{font-size:13px;color:var(--text-sec);line-height:1.6;}
.cfc-tile-body strong{color:var(--text);font-weight:700;}
@media(max-width:880px){.cfc-block{grid-template-columns:1fr;}}

/* ===== Ecosystem central insight callout ===== */
.ecosystem-callout{background:linear-gradient(135deg,var(--nhs-dark),var(--nhs-blue));color:#fff;border-radius:14px;padding:24px 28px;margin:14px 0 30px;border-left:6px solid var(--amber);}
.ecosystem-callout-eyebrow{font-size:10.5px;font-weight:800;letter-spacing:1.8px;color:var(--amber);text-transform:uppercase;margin-bottom:8px;}
.ecosystem-callout-line{font-size:22px;font-weight:900;color:#fff;letter-spacing:-0.5px;margin-bottom:10px;line-height:1.25;}
.ecosystem-callout-body{font-size:13px;color:rgba(255,255,255,0.90);line-height:1.65;}
.ecosystem-callout-body strong{color:#fff;font-weight:700;}

/* ===== Three layers — Input · Bridge · Output ===== */
.layers-wrap{margin-top:14px;}
.layers-grid{display:grid;grid-template-columns:1fr auto 1fr auto 1fr;gap:10px;align-items:stretch;}
.layer-card{background:#fff;border:1.5px solid var(--border-lt);border-radius:14px;padding:22px 22px 20px;display:flex;flex-direction:column;}
.layer-card.layer-input{border-color:var(--pale-blue-bd);background:#F4F8FC;}
.layer-card.layer-bridge{border-color:var(--amber);background:var(--warm-cream);box-shadow:0 8px 24px rgba(255,185,29,0.18);}
.layer-card.layer-output{border-color:#cfe1d8;background:#F4FAF7;}
.layer-eyebrow{font-size:10.5px;font-weight:800;letter-spacing:1.8px;text-transform:uppercase;margin-bottom:8px;}
.layer-card.layer-input .layer-eyebrow{color:var(--nhs-blue);}
.layer-card.layer-bridge .layer-eyebrow{color:var(--amber-deep);}
.layer-card.layer-output .layer-eyebrow{color:var(--nhs-green);}
.layer-h{font-size:18px;font-weight:900;color:var(--nhs-dark);letter-spacing:-0.4px;margin-bottom:8px;line-height:1.2;}
.layer-strap{font-size:11.5px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:12px;}
.layer-body{font-size:13px;color:var(--text-sec);line-height:1.6;margin-bottom:14px;}
.layer-body strong{color:var(--text);font-weight:700;}
.layer-list{font-size:12px;color:var(--text-sec);line-height:1.55;padding-left:0;list-style:none;margin-top:6px;}
.layer-list li{margin-bottom:4px;padding-left:14px;position:relative;}
.layer-list li::before{content:"";position:absolute;left:0;top:7px;width:7px;height:7px;border-radius:50%;background:var(--text-muted);}
.layer-card.layer-input .layer-list li::before{background:var(--nhs-blue);}
.layer-card.layer-bridge .layer-list li::before{background:var(--amber-deep);}
.layer-card.layer-output .layer-list li::before{background:var(--nhs-green);}
.layer-arrow{display:flex;align-items:center;justify-content:center;font-size:30px;font-weight:300;color:var(--text-muted);padding:0 4px;}
@media(max-width:980px){.layers-grid{grid-template-columns:1fr;}.layer-arrow{transform:rotate(90deg);padding:8px 0;}}

/* ===== Ownership strip ===== */
.own-strip{margin-top:22px;background:linear-gradient(135deg,var(--nhs-dark),var(--nhs-blue));color:#fff;border-radius:14px;padding:22px 28px;display:grid;grid-template-columns:1fr 1fr 1fr;gap:24px;}
.own-block-h{font-size:11px;font-weight:800;letter-spacing:1.6px;color:var(--amber);text-transform:uppercase;margin-bottom:6px;}
.own-block-body{font-size:13px;color:rgba(255,255,255,0.92);line-height:1.55;}
.own-block-body strong{color:#fff;font-weight:700;}
@media(max-width:880px){.own-strip{grid-template-columns:1fr;}}

/* ===== Three Steps strip (Referral · Fulfilment · Result) ===== */
.three-steps-wrap{margin-top:14px;}
.three-steps-grid{display:grid;grid-template-columns:1fr auto 1fr auto 1fr;gap:14px;align-items:stretch;}
.step-card{background:#fff;border:1.5px solid var(--border-lt);border-top:5px solid var(--nhs-blue);border-radius:14px;padding:22px 22px 20px;display:flex;flex-direction:column;}
.step-eyebrow{font-size:10.5px;font-weight:800;letter-spacing:1.8px;text-transform:uppercase;color:var(--nhs-blue);margin-bottom:8px;}
.step-h{font-size:18px;font-weight:900;color:var(--nhs-dark);letter-spacing:-0.4px;margin-bottom:10px;line-height:1.25;}
.step-body{font-size:13px;color:var(--text-sec);line-height:1.6;margin-bottom:12px;}
.step-body strong{color:var(--text);font-weight:700;}
.step-list{font-size:12px;color:var(--text-sec);line-height:1.55;padding-left:0;list-style:none;margin-top:auto;}
.step-list li{margin-bottom:4px;padding-left:14px;position:relative;}
.step-list li::before{content:"";position:absolute;left:0;top:7px;width:7px;height:7px;border-radius:50%;background:var(--nhs-blue);}
.step-arrow{display:flex;align-items:center;justify-content:center;font-size:30px;font-weight:300;color:var(--text-muted);padding:0 4px;}
.steps-anchor{font-size:13px;color:var(--text-sec);line-height:1.6;font-style:italic;margin-top:18px;text-align:center;}
.steps-anchor strong{color:var(--text);font-weight:700;font-style:normal;}
@media(max-width:980px){.three-steps-grid{grid-template-columns:1fr;}.step-arrow{transform:rotate(90deg);padding:8px 0;}}

/* Five questions diagram (kept from v1) */
.shape-wrap{display:grid;grid-template-columns:1.1fr 1fr;gap:30px;align-items:center;margin-top:4px;}
.shape-circle{position:relative;width:340px;height:340px;margin:0 auto;}
.shape-centre{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
              width:140px;height:140px;border-radius:50%;background:var(--nhs-dark);color:#fff;
              display:flex;flex-direction:column;align-items:center;justify-content:center;
              box-shadow:0 8px 20px rgba(0,48,135,0.28);}
.shape-centre-q{font-size:36px;font-weight:900;letter-spacing:-1px;}
.shape-centre-cap{font-size:10px;font-weight:800;letter-spacing:1.5px;margin-top:2px;opacity:0.88;}
.shape-pet{position:absolute;width:110px;height:110px;border-radius:50%;background:#fff;
           border:2px solid var(--nhs-blue);display:flex;flex-direction:column;align-items:center;
           justify-content:center;box-shadow:0 4px 12px rgba(0,48,135,0.16);}
.shape-pet-q{font-size:24px;font-weight:900;color:var(--nhs-blue);letter-spacing:-0.6px;line-height:1;}
.shape-pet-cap{font-size:9.5px;font-weight:800;letter-spacing:1.2px;color:var(--text-sec);text-transform:uppercase;margin-top:3px;}
.shape-pet.p-top{top:0;left:50%;transform:translateX(-50%);}
.shape-pet.p-right{top:50%;right:0;transform:translateY(-50%);}
.shape-pet.p-bottom{bottom:0;left:50%;transform:translateX(-50%);}
.shape-pet.p-left{top:50%;left:0;transform:translateY(-50%);}
.shape-list{font-size:14px;color:var(--text-sec);line-height:1.75;}
.shape-list strong{color:var(--nhs-dark);font-weight:800;}
.shape-list .item{margin-bottom:10px;}
.shape-list .item .icon{display:inline-block;width:24px;height:24px;border-radius:50%;
                        background:var(--nhs-blue);color:#fff;font-size:11px;font-weight:800;
                        text-align:center;line-height:24px;margin-right:10px;vertical-align:middle;}
.shape-list .item .icon.dark{background:var(--nhs-dark);}
.shape-list .item .icon.amber{background:var(--amber-deep);}
.shape-list .item .icon.green{background:var(--nhs-green);}
.shape-list .item .icon.pink{background:var(--nhs-pink);}
@media(max-width:880px){.shape-wrap{grid-template-columns:1fr;}.shape-circle{width:280px;height:280px;}.shape-pet{width:90px;height:90px;}}

/* Where to start tiles */
.start-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:14px;}
.start-tile{background:#fff;border:1px solid var(--border-lt);border-radius:14px;padding:22px 24px 20px;
            text-decoration:none;color:inherit;display:flex;gap:16px;align-items:flex-start;
            transition:transform 0.18s ease,box-shadow 0.22s ease,border-color 0.18s ease;
            border-left:5px solid var(--amber);}
.start-tile:hover{transform:translateY(-3px);box-shadow:0 14px 34px rgba(0,32,64,0.12);border-left-color:var(--amber-deep);}
.start-num{flex-shrink:0;width:40px;height:40px;border-radius:50%;background:var(--nhs-dark);color:#fff;
           font-size:18px;font-weight:900;display:flex;align-items:center;justify-content:center;margin-top:2px;}
.start-body{flex:1;}
.start-head{font-size:16px;font-weight:800;color:var(--nhs-dark);letter-spacing:-0.2px;margin-bottom:4px;}
.start-mins{font-size:10.5px;font-weight:800;letter-spacing:1.4px;color:var(--amber-deep);text-transform:uppercase;margin-bottom:8px;}
.start-desc{font-size:13px;color:var(--text-sec);line-height:1.6;}
.start-desc strong{color:var(--text);font-weight:700;}
@media(max-width:780px){.start-grid{grid-template-columns:1fr;}}

/* Audience cards */
.aud-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;}
.aud-card{background:var(--pale-blue);border:1px solid var(--pale-blue-bd);border-radius:12px;padding:18px 18px 16px;}
.aud-card-h{font-size:13px;font-weight:800;color:var(--nhs-dark);letter-spacing:-0.1px;margin-bottom:8px;}
.aud-card-body{font-size:12px;color:var(--text-sec);line-height:1.6;}
.aud-card-body strong{color:var(--text);font-weight:700;}
.aud-card-body a{color:var(--nhs-blue);font-weight:700;text-decoration:none;}
.aud-card-body a:hover{text-decoration:underline;}
@media(max-width:1000px){.aud-grid{grid-template-columns:repeat(2,1fr);}}
@media(max-width:540px){.aud-grid{grid-template-columns:1fr;}}

/* Honest expectations */
.honest{background:var(--warm-cream);border:1px solid #F0DCA0;border-radius:14px;padding:24px 28px;margin-top:8px;}
.honest p{font-size:13.5px;color:var(--text-sec);line-height:1.7;margin-bottom:12px;}
.honest p:last-child{margin-bottom:0;}
.honest p strong{color:var(--amber-deep);font-weight:800;}

/* CTA strip */
.cta{margin-top:48px;background:linear-gradient(135deg,var(--nhs-dark),var(--nhs-blue));color:#fff;border-radius:18px;
     padding:36px 40px;display:grid;grid-template-columns:1.4fr 1fr;gap:24px;align-items:center;}
.cta-text-h{font-size:24px;font-weight:900;letter-spacing:-0.5px;margin-bottom:8px;}
.cta-text-body{font-size:13.5px;color:rgba(255,255,255,0.88);line-height:1.6;}
.cta-btns{display:flex;flex-direction:column;gap:10px;}
.cta-btn-main{background:var(--amber);color:var(--nhs-dark);font-size:14.5px;font-weight:800;letter-spacing:0.3px;
              padding:14px 22px;border-radius:99px;text-decoration:none;text-align:center;
              transition:transform 0.15s,box-shadow 0.2s;}
.cta-btn-main:hover{transform:translateY(-1px);box-shadow:0 8px 20px rgba(0,0,0,0.18);}
.cta-btn-sec{background:transparent;color:#fff;font-size:12.5px;font-weight:700;letter-spacing:0.3px;
             padding:10px 22px;border:1.5px solid rgba(255,255,255,0.45);border-radius:99px;
             text-decoration:none;text-align:center;}
.cta-btn-sec:hover{background:rgba(255,255,255,0.10);}
@media(max-width:780px){.cta{grid-template-columns:1fr;}}

.foot{margin-top:36px;padding-top:22px;border-top:1px solid var(--border-lt);font-size:11.5px;color:var(--text-muted);text-align:center;}
</style>
</head>
