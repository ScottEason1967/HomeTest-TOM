  .status-section {
    background: white;
    border: 1px solid #e5e5e5;
    border-radius: 8px;
    padding: 16px 20px 14px;
    margin-bottom: 16px;
  }
  .status-section.open-section {
    background: #fef4f3;
    border: 1px solid #f5c6c2;
    border-left: 5px solid var(--status-open);
  }
  .status-section.decided-section {
    border-left: 5px solid var(--status-decided);
  }
  .status-section.progress-section {
    border-left: 5px solid var(--status-progress);
  }

  .status-heading {
    display: flex;
    align-items: center;
    gap: 9px;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.7px;
    margin-bottom: 10px;
  }
  .status-dot {
    width: 12px; height: 12px; border-radius: 50%; flex-shrink: 0;
  }
  .dot-decided { background: var(--status-decided); }
  .dot-progress { background: var(--status-progress); }
  .dot-open { background: var(--status-open); }
  .heading-decided { color: var(--status-decided); }
  .heading-progress { color: var(--status-progress); }
  .heading-open { color: var(--status-open); }
  .status-count {
    margin-left: auto;
    background: rgba(0,0,0,0.05);
    padding: 2px 9px;
    border-radius: 10px;
    font-size: 11px;
    color: #666;
  }
  .open-section .status-count {
    background: rgba(218,41,28,0.12);
    color: var(--status-open);
  }

  .status-list { list-style: none; padding: 0; margin: 0; }
  .status-list li {
    padding: 6px 0 6px 20px;
    position: relative;
    font-size: 13px;
    line-height: 1.5;
    color: #333;
    border-bottom: 1px solid #f0f0f0;
  }
  .status-list li:last-child { border-bottom: none; }
  .status-list li::before {
    content: '';
    position: absolute;
    left: 4px;
    top: 13px;
    width: 7px;
    height: 7px;
    border-radius: 50%;
  }
  .status-list.decided li::before { background: var(--status-decided); }
  .status-list.progress li::before { background: var(--status-progress); }
  .status-list.open li::before { background: var(--status-open); }
  .open-section .status-list li {
    font-weight: 500;
    color: #2a2a2a;
  }

  .split-block { margin-bottom: 26px; }
  .split-block-header {
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 8px 14px;
    border-radius: 5px 5px 0 0;
