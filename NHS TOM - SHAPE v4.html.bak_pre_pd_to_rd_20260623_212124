  .split-block-header.customer { background: #009639; }
  .split-block-body {
    border: 1px solid #e5e5e5;
    border-top: none;
    border-radius: 0 0 6px 6px;
    padding: 14px;
  }
  .split-block-body .status-section { margin-bottom: 12px; }
  .split-block-body .status-section:last-child { margin-bottom: 0; }

  .prev-next {
