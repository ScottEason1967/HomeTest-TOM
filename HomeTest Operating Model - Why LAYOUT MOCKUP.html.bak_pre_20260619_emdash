<title>Why page — LAYOUT MOCKUP v2 for review</title>
<style>
  :root{--nhs-dark:#003087;--nhs-blue:#005EB8;--nhs-blue-deep:#003087;--amber:#FFB91D;--amber-deep:#C9A227;--warm-cream:#FFF9EC;--accent:#1B3A6B;--text:#212B32;--text-sec:#4C6272;--text-muted:#7E8B97;--border-lt:#ebeef1;}
  *{box-sizing:border-box;margin:0;padding:0;}
  body{font-family:'Segoe UI',-apple-system,BlinkMacSystemFont,Helvetica,Arial,sans-serif;background:linear-gradient(180deg,var(--nhs-blue) 0%,var(--nhs-blue-deep) 100%);background-attachment:fixed;color:var(--text);line-height:1.5;-webkit-font-smoothing:antialiased;min-height:100vh;}
  .page{max-width:1100px;margin:30px auto 50px;padding:50px 40px 80px;background:#fff;border-radius:18px;box-shadow:0 14px 40px rgba(0,48,135,0.20);}
  .mockup-banner{background:#FFF3CD;border:1px solid #FFC107;border-radius:10px;padding:14px 20px;margin-bottom:30px;font-size:13.5px;color:#856404;}
  .mockup-banner strong{color:#664d03;}
  .amber-rule{width:72px;height:4px;background:var(--amber);border-radius:2px;margin-bottom:18px;}
  .h-eyebrow{font-size:11px;font-weight:700;letter-spacing:2.2px;color:var(--text-sec);text-transform:uppercase;margin-bottom:18px;}
  .h-title{font-size:54px;font-weight:800;color:var(--nhs-dark);letter-spacing:-1.4px;line-height:1.05;margin-bottom:14px;}
  .h-sub{font-size:15.5px;color:var(--text-sec);line-height:1.7;margin-bottom:24px;}
</style>
