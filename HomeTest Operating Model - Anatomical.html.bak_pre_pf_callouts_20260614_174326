<!DOCTYPE html>
<html lang="en-GB">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>HomeTest Operating Model: Anatomical</title>
<style>
  :root {
    --nhs-dark:#003087; --nhs-blue:#005EB8; --nhs-green:#006747; --nhs-pink:#AE2573;
    --amber:#FFB91D; --amber-deep:#C9A227; --warm-cream:#FFF9EC;
    --accent:var(--nhs-dark);
    --text:#212B32; --text-sec:#4C6272; --text-muted:#7E8B97;
    --border:#d9dee3; --border-lt:#ebeef1;
    --card:#ffffff; --bg:#f8fafc;
  }
  .amber-rule { width: 72px; height: 4px; background: var(--amber); border-radius: 2px; margin-bottom: 18px; }
  .persona-strip { display: flex; gap: 14px; align-items: center; padding: 18px 22px; background: var(--warm-cream); border: 1px solid #F0DCA0; border-radius: 12px; margin: 24px 0; }
  .persona-strip img { width: 64px; height: auto; flex-shrink: 0; }
  .persona-strip-text { flex: 1; }
  .persona-strip-name { font-size: 11px; font-weight: 800; letter-spacing: 1.4px; color: var(--amber-deep); text-transform: uppercase; margin-bottom: 4px; }
  .persona-strip-body { font-size: 13px; color: var(--text-sec); line-height: 1.6; }
  .persona-strip-body strong { color: var(--text); font-weight: 700; }
  *{box-sizing:border-box;margin:0;padding:0;}
  body{font-family:'Segoe UI',-apple-system,BlinkMacSystemFont,Helvetica,Arial,sans-serif;background:var(--bg);color:var(--text);line-height:1.5;-webkit-font-smoothing:antialiased;}
  .topnav{background:#fff;border-bottom:1px solid var(--border-lt);padding:14px 36px;display:flex;align-items:center;justify-content:space-between;gap:24px;flex-wrap:wrap;}
  .nav-back{font-size:13px;font-weight:700;color:var(--nhs-dark);text-decoration:none;display:inline-flex;align-items:center;gap:6px;}
  .nav-back:hover{color:var(--nhs-blue);}
  .nav-siblings{display:flex;gap:4px;flex-wrap:wrap;}
  .nav-siblings a{font-size:12.5px;font-weight:600;color:var(--text-sec);text-decoration:none;padding:7px 14px;border-radius:6px;letter-spacing:0.2px;}
  .nav-siblings a:hover{background:#f0f4f8;color:var(--text);}
  .nav-siblings a.active{background:var(--accent);color:#fff;}
  .page{max-width:1180px;margin:0 auto;padding:50px 40px 80px;}
  .header{margin-bottom:42px;}
  .h-eyebrow{display:inline-block;background:var(--accent);color:#fff;font-size:10.5px;font-weight:800;letter-spacing:1.8px;padding:7px 16px;border-radius:4px;text-transform:uppercase;margin-bottom:18px;}
  .h-title{font-size:42px;font-weight:800;color:var(--nhs-dark);letter-spacing:-0.5px;line-height:1.1;margin-bottom:12px;}
  .h-subtitle{font-size:18px;color:var(--text-sec);font-weight:500;margin-bottom:18px;}
  .h-intro{max-width:820px;font-size:14.5px;color:var(--text-sec);line-height:1.7;}
  .h-intro strong{color:var(--text);font-weight:700;}
  /* Vocabulary cards */
  .vocab{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-top:30px;margin-bottom:30px;}
  .vc{background:#fff;border:1px solid var(--border-lt);border-radius:10px;padding:18px;box-shadow:0 1px 3px rgba(0,32,64,0.04);}
  .vc-badge{display:inline-block;background:#f0f4f8;color:var(--text-sec);font-size:9.5px;font-weight:800;letter-spacing:0.8px;padding:3px 9px;border-radius:4px;text-transform:uppercase;margin-bottom:8px;}
  .vc.l1 .vc-badge{background:var(--nhs-dark);color:#fff;}
  .vc.l2 .vc-badge{background:var(--nhs-blue);color:#fff;}
  .vc.l3 .vc-badge{background:#78909C;color:#fff;}
  .vc.l4 .vc-badge{background:var(--nhs-pink);color:#fff;}
  .vc-name{font-size:18px;font-weight:800;color:var(--text);margin-bottom:8px;letter-spacing:-0.2px;}
  .vc-body{font-size:12.5px;color:var(--text-sec);line-height:1.6;}
  .vc-body strong{color:var(--text);font-weight:700;}
  /* Four-level stack visual */
  .fls{display:flex;flex-direction:column;gap:8px;margin:30px 0;}
  .fls-band{border-radius:12px;padding:18px 22px;}
  .fls-band-l1{background:linear-gradient(135deg,#001F5C,#003087);color:#fff;}
  .fls-band-l2{background:linear-gradient(135deg,#003F8B,#005EB8);color:#fff;}
  .fls-band-l3{background:linear-gradient(135deg,#D5E8F0,#E8F1F6);color:var(--text);border:1px solid rgba(0,94,184,0.20);}
  .fls-band-l4{background:linear-gradient(135deg,#F5F8FC,#FAFBFD);color:var(--text);border:1px solid rgba(0,94,184,0.16);}
  .fls-head{display:flex;align-items:baseline;gap:14px;margin-bottom:6px;}
  .fls-num{font-size:10.5px;font-weight:800;letter-spacing:1.6px;opacity:0.78;}
  .fls-name{font-size:18px;font-weight:800;}
  .fls-tag{font-size:11.5px;font-weight:500;opacity:0.85;}
  .fls-l1 .fls-tag,.fls-l2 .fls-tag{color:rgba(255,255,255,0.85);}
  .fls-body{font-size:12.5px;line-height:1.65;opacity:0.92;max-width:820px;}
  /* Note */
  .note{display:flex;gap:14px;margin-top:20px;padding:14px 18px;background:#FFF8E1;border-left:4px solid #F9A825;border-radius:0 8px 8px 0;}
  .note-tag{flex-shrink:0;font-size:10px;font-weight:800;letter-spacing:1.2px;text-transform:uppercase;color:#8D6E1A;min-width:120px;padding-top:2px;}
  .note-body{font-size:12px;color:var(--text-sec);line-height:1.6;}
  .note-body strong{color:var(--text);font-weight:700;}
  /* Deep-dive link */
  .deepdive{margin-top:40px;background:#fff;border:1px solid var(--border-lt);border-radius:12px;padding:22px 26px;display:flex;align-items:center;gap:24px;justify-content:space-between;flex-wrap:wrap;}
  .deepdive-text h3{font-size:15px;font-weight:800;color:var(--text);margin-bottom:6px;}
  .deepdive-text p{font-size:12.5px;color:var(--text-sec);line-height:1.6;max-width:700px;}
  .deepdive-cta{flex-shrink:0;background:var(--accent);color:#fff;text-decoration:none;font-size:13px;font-weight:700;padding:11px 22px;border-radius:6px;}
  .deepdive-cta:hover{background:var(--nhs-blue);}
  .foot{margin-top:48px;text-align:center;font-size:11.5px;color:var(--text-muted);line-height:1.6;}
  .foot strong{color:var(--text-sec);font-weight:700;}
  @media(max-width:820px){
    .vocab{grid-template-columns:1fr 1fr;}
    .h-title{font-size:30px;}
    .page{padding:30px 22px 60px;}
    .topnav{padding:12px 20px;}
  }

  /* Catalogue + swimlanes variables */
  :root {
    --green: #007F3B;
    --amber: #9A6700;
    --amber-bg: #fef6e6;
    --amber-lt: #fffbf2;
    --red: #B5121B;
    --red-bg: #fce8e9;
    --platform: #D0E4F8;
    --platform-dark: #005EB8;
    --framework: #E0D4F0;
    --framework-dark: #5B3A8C;
    --supplier: #F0E8D8;
    --supplier-dark: #7A5A20;
    --commissioner: #D8F0D8;
    --commissioner-dark: #2A6A2A;
    --clinical: #F8E0E0;
    --clinical-dark: #8A2020;
    --patient: #E8E8E8;
    --patient-dark: #444444;
    --foundation-bg: #e8f1fb;
    --foundation-border: #005EB8;
    --foundation-dark: #003087;
    --overlay-bg: #fff8e8;
    --overlay-border: #B5651D;
    --overlay-dark: #B5651D;
  }
  /* Section heading */
  .section-h { display:flex; align-items:center; gap:14px; font-size:22px; font-weight:800; color:var(--nhs-dark); margin:48px 0 18px; letter-spacing:-0.2px; }
  .section-h .num { display:inline-flex; align-items:center; justify-content:center; width:34px; height:34px; border-radius:50%; background:var(--accent); color:#fff; font-size:13px; font-weight:800; }
  /* Catalogue */
  .catalogue-card { background:#fff; border:1px solid var(--border-lt); border-radius:12px; overflow:hidden; margin-bottom:18px; box-shadow:0 1px 3px rgba(0,32,64,0.04); }
  .catalogue-head { padding:18px 24px; border-bottom:1px solid var(--border-lt); background:linear-gradient(90deg,#f5f8fc,#fafbfd); display:flex; justify-content:space-between; align-items:flex-start; gap:20px; flex-wrap:wrap; }
  .catalogue-head .ch-text h3 { font-size:17px; font-weight:800; color:var(--nhs-dark); margin-bottom:4px; }
  .catalogue-head .ch-text p { font-size:12px; color:var(--text-sec); line-height:1.55; max-width:760px; }
  .catalogue-head .ratio { background:linear-gradient(135deg,var(--nhs-dark),var(--nhs-blue)); color:#fff; border-radius:10px; padding:14px 22px; min-width:240px; }
  .catalogue-head .ratio .rlabel { font-size:9.5px; font-weight:800; letter-spacing:1px; text-transform:uppercase; opacity:0.8; }
  .catalogue-head .ratio .rstat { font-size:30px; font-weight:900; line-height:1.1; margin:4px 0; letter-spacing:-1px; }
  .catalogue-head .ratio .rdesc { font-size:11px; line-height:1.45; opacity:0.92; }
  .cat-table { width:100%; border-collapse:collapse; }
  .cat-table thead th { background:#f0f3f6; font-size:11px; font-weight:800; color:var(--text); padding:11px 14px; text-align:left; border-bottom:2px solid var(--border-lt); letter-spacing:0.3px; }
  .cat-table thead th.col-overlay { width:200px; }
  .cat-table thead th.col-hiv { background:#006747; color:#fff; }
  .cat-table thead th.col-psa { background:#AE2573; color:#fff; }
  .cat-table tbody td.cell-hiv { border-left:3px solid #006747; }
  .cat-table tbody td.cell-psa { border-left:3px solid #AE2573; }
  .cat-table tbody td { font-size:11.5px; color:var(--text-sec); padding:11px 14px; border-bottom:1px solid var(--border-lt); line-height:1.55; vertical-align:top; }
  .cat-table tbody tr.foundation td { background:var(--foundation-bg); }
  .cat-table tbody tr.foundation td:first-child { font-weight:700; color:var(--foundation-dark); border-left:4px solid var(--foundation-border); }
  .cat-table tbody tr.overlay td { background:var(--overlay-bg); }
  .cat-table tbody tr.overlay td:first-child { font-weight:700; color:var(--overlay-dark); border-left:4px solid var(--overlay-border); }
  .cat-table tbody td .badge { display:inline-block; padding:2px 8px; border-radius:10px; font-size:9px; font-weight:800; letter-spacing:0.5px; text-transform:uppercase; margin-right:6px; vertical-align:1px; }
  .cat-table tbody tr.foundation td .badge { background:var(--foundation-dark); color:#fff; }
  .cat-table tbody tr.overlay td .badge { background:var(--overlay-dark); color:#fff; }
  .cat-table tbody td.same { font-style:italic; color:var(--foundation-dark); }
  .cat-table tbody td.same::before { content:"\2192 "; font-weight:800; font-style:normal; }
  .cat-section-row td { background:#e0e6ec !important; font-weight:800; color:var(--text-muted); letter-spacing:1px; text-transform:uppercase; font-size:10px; padding:8px 14px !important; border-left:none !important; border-bottom:1px solid var(--border-lt) !important; }
  .cat-foot { padding:14px 22px; font-size:11px; color:var(--text-sec); line-height:1.6; background:#fafbfc; border-top:1px solid var(--border-lt); }
  .cat-foot strong { color:var(--text); }
  .gap-flag { background:var(--red-bg); border:1px solid #f0b3b5; border-radius:6px; padding:3px 8px; font-size:9px; font-weight:700; color:var(--red); display:inline-block; margin-top:4px; }
  .new-flag { background:#fef3c7; border:1px solid #f5d787; border-radius:6px; padding:3px 8px; font-size:9px; font-weight:700; color:#92580a; display:inline-block; margin-top:4px; }

  /* North stars */
  .section-h { font-size:11.5px; font-weight:800; letter-spacing:1.2px; text-transform:uppercase; color:var(--text-muted); margin:30px 0 14px 4px; display:flex; align-items:center; gap:10px; }
  .section-h .num { background:var(--nhs-blue); color:#fff; padding:3px 10px; border-radius:14px; font-size:10px; font-weight:800; letter-spacing:0.5px; }
  .intent { background:linear-gradient(135deg,#fafbfc,#fff); border:1px solid var(--border); border-radius:10px; padding:20px 24px; margin-bottom:14px; }
  .intent h2 { font-size:15px; font-weight:800; color:var(--nhs-dark); margin-bottom:6px; letter-spacing:-0.2px; }
  .intent p { font-size:12.5px; color:var(--text-sec); line-height:1.65; margin-bottom:8px; }
  .intent p:last-child { margin-bottom:0; }
  .intent strong { color:var(--text); font-weight:700; }
  .patient-mission { background:linear-gradient(135deg,#003087,#005EB8); color:#fff; border-radius:12px; padding:18px 24px; margin:14px 0 18px; display:flex; gap:18px; align-items:flex-start; box-shadow:0 4px 14px rgba(0,48,135,0.10); }
  .patient-mission .pm-tag { flex-shrink:0; font-size:10px; font-weight:800; letter-spacing:1.4px; text-transform:uppercase; padding:5px 12px; background:rgba(255,255,255,0.18); border-radius:4px; min-width:78px; text-align:center; }
  .patient-mission .pm-body { font-size:13px; line-height:1.6; font-weight:500; }
  .nstars { display:grid; grid-template-columns:repeat(3,1fr); gap:16px; margin:14px 0 18px; }
  .nstar { background:#fff; border:1px solid var(--border); border-radius:12px; padding:18px 20px 18px 22px; position:relative; overflow:hidden; box-shadow:0 4px 14px rgba(0,48,135,0.06); transition:transform 0.15s, box-shadow 0.15s; }
  .nstar:hover { transform:translateY(-2px); box-shadow:0 8px 22px rgba(0,48,135,0.12); }
  .nstar::before { content:""; position:absolute; left:0; top:0; bottom:0; width:6px; }
  .nstar.commissioner::before { background:linear-gradient(180deg,#003087,#1976D2); }
  .nstar.supplier::before { background:linear-gradient(180deg,#006747,#00A86B); }
  .nstar.hometest::before { background:linear-gradient(180deg,#AE2573,#D946A8); }
  .nstar .nstar-icon { position:absolute; top:14px; right:16px; width:42px; height:42px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:22px; color:#fff; box-shadow:0 2px 8px rgba(0,0,0,0.12); }
  .nstar .nstar-portrait { position:absolute; top:14px; right:14px; width:46px; height:46px; }
  .nstar .nstar-portrait img { width:100%; height:100%; display:block; border-radius:50%; border:2px solid var(--amber); background:var(--warm-cream); object-fit:cover; object-position:top center; }
  .nstar .nlabel { padding-right:60px; }
  .nstar.commissioner .nstar-icon { background:linear-gradient(135deg,#003087,#1976D2); }
  .nstar.supplier .nstar-icon { background:linear-gradient(135deg,#006747,#00A86B); }
  .nstar.hometest .nstar-icon { background:linear-gradient(135deg,#AE2573,#D946A8); }
  .nstar .nlabel { font-size:9.5px; font-weight:800; letter-spacing:1.2px; text-transform:uppercase; margin-bottom:4px; padding-right:60px; }
  .nstar.commissioner .nlabel { color:#003087; }
  .nstar.supplier .nlabel { color:#006747; }
  .nstar.hometest .nlabel { color:#AE2573; }
  .nstar .nheadline { font-size:15px; font-weight:800; color:var(--text); margin-bottom:6px; padding-right:60px; letter-spacing:-0.2px; }
  .nstar .nbody { font-size:11.5px; color:var(--text-sec); line-height:1.55; }
  @media(max-width:900px) { .nstars { grid-template-columns:1fr; } }
  @media(max-width:900px) { .hdr-in{flex-direction:column;} .vocab{grid-template-columns:1fr 1fr;} .nstars{flex-direction:column;} .catalogue-head{flex-direction:column;} .fls-split{grid-template-columns:1fr;} .fls-pill-overlay{min-width:100px;} }

  /* Four-level stack */
  .fls { margin:18px 0 8px 0; display:flex; flex-direction:column; gap:10px; }
  .fls-level { border-radius:14px; padding:18px 22px 20px 22px; position:relative; box-shadow:0 2px 6px rgba(0,32,64,0.06); }
  .fls-l1 { background:linear-gradient(135deg, rgba(0,48,135,0.96), rgba(0,48,135,0.84)); color:#fff; }
  .fls-l2 { background:linear-gradient(135deg, rgba(0,94,184,0.92), rgba(0,94,184,0.78)); color:#fff; }
  .fls-l3 { background:linear-gradient(135deg, rgba(213,232,240,0.92), rgba(213,232,240,0.55)); color:var(--text); border:1px solid rgba(0,94,184,0.20); }
  .fls-l4 { background:linear-gradient(135deg, rgba(245,248,252,0.95), rgba(248,251,254,0.92)); color:var(--text); border:1px solid rgba(0,94,184,0.16); }
  .fls-head { display:flex; align-items:baseline; gap:14px; margin-bottom:12px; flex-wrap:wrap; }
  .fls-num { font-size:11px; font-weight:800; letter-spacing:1.8px; opacity:0.78; }
  .fls-name { font-size:18px; font-weight:800; letter-spacing:0.3px; }
  .fls-tag { font-size:12.5px; font-weight:500; opacity:0.82; }
  .fls-l1 .fls-tag, .fls-l2 .fls-tag { color:rgba(255,255,255,0.88); }
  .fls-shared { display:flex; flex-wrap:wrap; gap:8px; }
  .fls-chip { display:inline-block; padding:6px 12px; border-radius:7px; background:rgba(255,255,255,0.18); color:#fff; font-size:12px; font-weight:600; border:1px solid rgba(255,255,255,0.24); }
  .fls-l3 .fls-chip, .fls-l4 .fls-chip { background:rgba(0,94,184,0.10); color:var(--nhs-dark); border-color:rgba(0,94,184,0.22); }
  .fls-split { display:grid; grid-template-columns:1fr 1fr; gap:16px; }
  .fls-split-4 { display:grid; grid-template-columns:repeat(4, 1fr); gap:12px; }
  .fls-split-4 .fls-col { padding:14px 12px; }
  .fls-split-4 .fls-pill-overlay { min-width:0; font-size:10.5px; }
  .fls-split-4 .fls-pill { font-size:10.5px; padding:3px 9px; }
  .fls-split-4 .fls-pill-row { font-size:10.5px; gap:6px; flex-wrap:wrap; }
  @media (max-width:1100px) { .fls-split-4 { grid-template-columns:1fr 1fr; } }
  @media (max-width:700px)  { .fls-split-4 { grid-template-columns:1fr; } }
  .fls-col { background:#fff; border-radius:10px; padding:14px 18px; box-shadow:0 1px 3px rgba(0,32,64,0.06); }
  .fls-col-hiv { border-top:4px solid #009688; }
  .fls-col-psa { border-top:4px solid #E91E63; }
  .fls-col-head { display:flex; align-items:center; justify-content:center; gap:10px; margin-bottom:10px; padding-bottom:8px; border-bottom:1px solid var(--border-lt); }
  .fls-col-name { font-weight:800; font-size:14px; letter-spacing:0.5px; }
  .fls-col-name-hiv { color:#009688; }
  .fls-col-name-psa { color:#E91E63; }
  .fls-badge { display:inline-block; font-size:9.5px; padding:3px 9px; border-radius:999px; font-weight:700; letter-spacing:0.6px; text-transform:uppercase; }
  .fls-badge-live { background:#009688; color:#fff; }
  .fls-badge-prospective { background:#FFE082; color:#5D4037; }
  .fls-pill-list { display:flex; flex-direction:column; gap:7px; }
  .fls-pill-row { display:flex; align-items:center; gap:10px; font-size:12px; text-decoration:none; color:inherit; cursor:pointer; padding:3px 4px; margin-left:-4px; margin-right:-4px; border-radius:6px; transition:background 0.15s; }
  .fls-pill-row:hover { background:#F4F8FC; }
  .fls-pill-row:hover .fls-pill-overlay { color:var(--nhs-blue); }
  .fls-pill-overlay { font-weight:600; color:#455A64; min-width:120px; flex-shrink:0; font-size:11.5px; }
  .fls-pill { display:inline-block; padding:4px 12px; border-radius:999px; font-size:11.5px; font-weight:700; color:#fff; }
  .fls-pill-hiv { background:#009688; }
  .fls-pill-psa { background:#E91E63; }
  .fls-col-hba1c { border-top:4px dashed #FB8C00; }
  .fls-col-pharmacy { border-top:4px dotted #7E57C2; opacity:0.82; }
  .fls-col-name-hba1c { color:#E65100; }
  .fls-col-name-pharmacy { color:#5E35B2; }
  .fls-pill-hba1c { background:#FB8C00; }
  .fls-pill-pharmacy { background:#9575CD; }
  .fls-badge-design { background:#FFE0B2; color:#E65100; }
  .fls-badge-assumption { background:#EDE7F6; color:#5E35B2; border:1px dashed #B39DDB; }
  .fls-config-text { font-size:12.5px; line-height:1.6; color:var(--text-sec); }
  .fls-config-text strong { color:var(--text); font-weight:700; }
  .fls-foot { font-size:11.5px; color:var(--text-muted); line-height:1.55; margin-top:14px; padding:12px 16px; background:#f8f9fb; border-radius:8px; }
  .fls-foot strong { color:var(--text-sec); }
  .fls-note { display:flex; gap:14px; margin-top:10px; padding:14px 18px; background:#FFF8E1; border-left:4px solid #F9A825; border-radius:0 8px 8px 0; }
  .fls-note-tag { flex-shrink:0; font-size:10px; font-weight:800; letter-spacing:1.2px; text-transform:uppercase; color:#8D6E1A; min-width:130px; padding-top:2px; }
  .fls-note-body { font-size:12px; color:var(--text-sec); line-height:1.6; }
