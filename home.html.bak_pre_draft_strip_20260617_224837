<script>
(async function syncStatusCounts(){
  try {
    const r = await fetch('HomeTest Operating Model - Status.html');
    if (!r.ok) return;
    const html = await r.text();
    const doc = new DOMParser().parseFromString(html, 'text/html');
    const counts = doc.querySelectorAll('.sum-count');
    if (counts.length < 2) return;
    const u = document.getElementById('home-count-unresolved');
    const p = document.getElementById('home-count-in-progress');
    if (u) u.textContent = counts[0].textContent.trim();
    if (p) p.textContent = counts[1].textContent.trim();
  } catch (e) {}
})();
</script>

