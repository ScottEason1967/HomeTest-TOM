<html lang="en-GB">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>HomeTest Operating Model: Ecosystem</title>
<style>
  :root {
    --nhs-dark:#003087; --nhs-blue:#005EB8; --nhs-green:#006747; --nhs-pink:#AE2573;
    --nhs-cyan:#00A9CE;
    --amber:#FFB91D; --amber-deep:#C9A227; --warm-cream:#FFF9EC;
    --accent:var(--nhs-cyan);
    --text:#212B32; --text-sec:#4C6272; --text-muted:#7E8B97;
    --border:#d9dee3; --border-lt:#ebeef1;
    --card:#ffffff; --bg:#f8fafc;

    --c-consumed:#00A9CE;
    --c-regulated:#7C2855;
    --c-contracted:#C9A227;
    --c-served:#006747;
  }
  *{box-sizing:border-box;margin:0;padding:0;}
  body{font-family:'Segoe UI',-apple-system,BlinkMacSystemFont,Helvetica,Arial,sans-serif;background:var(--bg);color:var(--text);line-height:1.5;-webkit-font-smoothing:antialiased;}
  .topnav{background:#fff;border-bottom:1px solid var(--border-lt);padding:14px 36px;display:flex;align-items:center;justify-content:space-between;gap:24px;flex-wrap:wrap;}
  .nav-back{font-size:13px;font-weight:700;color:var(--nhs-dark);text-decoration:none;}
  .nav-back:hover{color:var(--nhs-blue);}
  .nav-siblings{display:flex;gap:4px;flex-wrap:wrap;}
  .nav-siblings a{font-size:12.5px;font-weight:600;color:var(--text-sec);text-decoration:none;padding:7px 14px;border-radius:6px;letter-spacing:0.2px;}
  .nav-siblings a:hover{background:#f0f4f8;color:var(--text);}
  .nav-siblings a.active{background:var(--nhs-dark);color:#fff;}

  .page{max-width:1180px;margin:0 auto;padding:50px 40px 80px;}
  .header{margin-bottom:24px;}
  .amber-rule{width:72px;height:4px;background:var(--amber);border-radius:2px;margin-bottom:18px;}
  .h-eyebrow{display:inline-block;background:var(--nhs-cyan);color:#fff;font-size:10.5px;font-weight:800;letter-spacing:1.8px;padding:7px 16px;border-radius:4px;text-transform:uppercase;margin-bottom:18px;}
  .h-mega{font-size:72px;font-weight:900;color:var(--nhs-cyan);letter-spacing:-2px;line-height:0.95;margin:6px 0 6px;}
  .h-title{font-size:30px;font-weight:800;color:var(--nhs-dark);letter-spacing:-0.5px;line-height:1.15;margin-bottom:10px;}
  .h-subtitle{font-size:16px;color:var(--text-sec);font-weight:500;margin-bottom:12px;}
  .h-intro{max-width:880px;font-size:14px;color:var(--text-sec);line-height:1.7;}
  .h-intro strong{color:var(--text);font-weight:700;}

  .what-sub{display:flex;gap:8px;margin:0 0 22px;padding:8px;background:#f4f8fc;border-radius:10px;border:1px solid var(--border-lt);width:fit-content;}
  .what-sub a{font-size:12px;font-weight:700;color:var(--text-sec);text-decoration:none;padding:8px 14px;border-radius:6px;letter-spacing:0.3px;}
  .what-sub a.active{background:var(--nhs-cyan);color:#fff;}
  .what-sub a:hover:not(.active){background:#e3edf8;color:var(--text);}

  /* === HUB AND SPOKE === */
  .hub-frame{position:relative;background:linear-gradient(180deg,#f4f8fc,#ffffff);border:1px solid var(--border-lt);border-radius:18px;padding:30px;margin:14px 0 24px;overflow:hidden;}
  .hub-frame::before{content:'';position:absolute;top:-80px;right:-80px;width:280px;height:280px;border-radius:50%;background:rgba(0,169,206,0.05);}
  .hub-frame::after{content:'';position:absolute;bottom:-100px;left:-100px;width:320px;height:320px;border-radius:50%;background:rgba(0,48,135,0.03);}

  .hub-grid{position:relative;display:grid;grid-template-columns:1fr 1.2fr 1fr;grid-template-rows:auto auto auto;gap:34px 34px;align-items:stretch;z-index:2;}
  .hub-spokes{position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:1;}
  .hub-spokes line{stroke:#b6c8de;stroke-width:2;stroke-linecap:round;}
  .hub-spokes .arrow{fill:#8aa3c4;}

  .hub-cardinal{background:#fff;border:1px solid var(--border-lt);border-radius:14px;padding:18px 18px 16px;display:flex;flex-direction:column;gap:10px;cursor:pointer;text-decoration:none;color:inherit;transition:transform 0.15s, box-shadow 0.18s, border-color 0.15s;position:relative;}
  .hub-cardinal:hover{transform:translateY(-2px);box-shadow:0 12px 28px rgba(0,32,64,0.10);}
  .hub-cardinal-consumed{border-top:5px solid var(--c-consumed);}
  .hub-cardinal-regulated{border-top:5px solid var(--c-regulated);}
  .hub-cardinal-contracted{border-top:5px solid var(--c-contracted);}
  .hub-cardinal-served{border-top:5px solid var(--c-served);}

  .hub-cardinal-head{display:flex;align-items:center;gap:10px;}
  .hub-cardinal-num{width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:900;color:#fff;flex-shrink:0;}
  .hub-cardinal-consumed .hub-cardinal-num{background:var(--c-consumed);}
  .hub-cardinal-regulated .hub-cardinal-num{background:var(--c-regulated);}
  .hub-cardinal-contracted .hub-cardinal-num{background:var(--c-contracted);}
  .hub-cardinal-served .hub-cardinal-num{background:var(--c-served);}
  .hub-cardinal-name{font-size:14px;font-weight:800;color:var(--text);letter-spacing:-0.1px;flex:1;}
  .hub-cardinal-count{font-size:10px;font-weight:700;color:var(--text-muted);background:#f4f6f8;padding:3px 8px;border-radius:999px;letter-spacing:0.3px;flex-shrink:0;}
  .hub-cardinal-line{font-size:11.5px;color:var(--text-sec);line-height:1.5;}
  .hub-cardinal-chips{display:flex;flex-wrap:wrap;gap:5px;}
  .hub-cardinal-chips span{font-size:10.5px;font-weight:600;color:var(--text-sec);background:#f4f6f8;padding:4px 9px;border-radius:5px;}
  .hub-cardinal-jump{font-size:10.5px;font-weight:700;color:var(--nhs-blue);letter-spacing:0.4px;text-transform:uppercase;margin-top:auto;padding-top:6px;}

  /* Position the cardinals on the grid */
  .hub-top    {grid-column:2;grid-row:1;}
  .hub-right  {grid-column:3;grid-row:2;}
  .hub-bottom {grid-column:2;grid-row:3;}
  .hub-left   {grid-column:1;grid-row:2;}

  /* Centre block — HomeTest */
  .hub-centre{grid-column:2;grid-row:2;background:linear-gradient(135deg,var(--nhs-dark),var(--nhs-blue));color:#fff;border-radius:14px;padding:24px 22px 22px;position:relative;display:flex;flex-direction:column;gap:10px;box-shadow:0 12px 36px rgba(0,48,135,0.30);}
  .hub-centre-logo{position:absolute;top:14px;right:18px;height:22px;background:#fff;padding:5px 8px;border-radius:5px;}
  .hub-centre-label{font-size:10px;font-weight:800;letter-spacing:1.6px;text-transform:uppercase;color:rgba(255,255,255,0.7);}
  .hub-centre-name{font-size:18px;font-weight:800;letter-spacing:-0.2px;line-height:1.2;max-width:80%;}
  .hub-centre-line{font-size:11.5px;color:rgba(255,255,255,0.88);line-height:1.55;}
  .hub-centre-chips{display:flex;flex-wrap:wrap;gap:5px;margin-top:4px;}
  .hub-centre-chips span{font-size:10px;font-weight:600;color:#fff;background:rgba(255,255,255,0.16);border:1px solid rgba(255,255,255,0.24);padding:4px 8px;border-radius:5px;}
  .hub-centre-jump{font-size:10px;font-weight:700;color:#bce7f0;letter-spacing:0.4px;text-transform:uppercase;margin-top:auto;}

  /* Mobile: stack into a vertical list, hide spokes */
  @media(max-width:820px){
    .hub-grid{grid-template-columns:1fr;grid-template-rows:auto auto auto auto auto;gap:14px;}
    .hub-top{grid-column:1;grid-row:1;}
    .hub-centre{grid-column:1;grid-row:2;}
    .hub-right{grid-column:1;grid-row:3;}
    .hub-bottom{grid-column:1;grid-row:4;}
    .hub-left{grid-column:1;grid-row:5;}
    .hub-spokes{display:none;}
  }

  /* === Detail accordions below the hub === */
  .detail-section{margin-top:34px;}
  .detail-section-h{font-size:14px;font-weight:800;letter-spacing:1.4px;text-transform:uppercase;color:var(--text-muted);margin-bottom:12px;}
  .detail-cards{display:grid;grid-template-columns:1fr;gap:8px;}
  details.detail-card{background:#fff;border:1px solid var(--border-lt);border-radius:10px;overflow:hidden;}
  details.detail-card[open]{box-shadow:0 4px 14px rgba(0,32,64,0.08);}
  details.detail-card summary{list-style:none;cursor:pointer;padding:12px 18px;display:grid;grid-template-columns:28px 1fr auto;gap:12px;align-items:center;user-select:none;}
  details.detail-card summary::-webkit-details-marker{display:none;}
  .d-num{width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10.5px;font-weight:900;color:#fff;}
  details.d-built .d-num{background:var(--nhs-blue);}
  details.d-consumed .d-num{background:var(--c-consumed);}
  details.d-regulated .d-num{background:var(--c-regulated);}
  details.d-contracted .d-num{background:var(--c-contracted);}
  details.d-served .d-num{background:var(--c-served);}
  .d-head{display:flex;flex-direction:column;gap:2px;min-width:0;}
  .d-name{font-size:13.5px;font-weight:800;color:var(--text);letter-spacing:-0.1px;}
  .d-line{font-size:11.5px;color:var(--text-sec);line-height:1.45;}
  .d-count{font-size:10.5px;font-weight:700;color:var(--text-muted);background:#f4f6f8;padding:4px 10px;border-radius:999px;}
  details.detail-card summary::after{content:'\25BC';font-size:9px;color:var(--text-muted);margin-left:6px;transition:transform 0.18s;}
  details.detail-card[open] summary::after{transform:rotate(180deg);}
  .d-body{padding:6px 18px 16px;border-top:1px solid var(--border-lt);}
  .d-entities{display:flex;flex-direction:column;gap:6px;margin-top:8px;}
  .d-entity{display:grid;grid-template-columns:180px 1fr;gap:16px;padding:8px 0;border-bottom:1px solid #f1f4f7;}
  .d-entity:last-child{border-bottom:none;}
  .d-entity-name{font-size:12px;font-weight:700;color:var(--text);}
  .d-entity-line{font-size:11.5px;color:var(--text-sec);line-height:1.55;}
  @media(max-width:680px){.d-entity{grid-template-columns:1fr;gap:3px;}}

  .eco-bau-note{background:#FFF8E6;border-left:4px solid var(--amber-deep);padding:14px 20px;border-radius:0 8px 8px 0;margin-top:20px;}
  .eco-bau-h{font-size:11px;font-weight:800;letter-spacing:1.2px;text-transform:uppercase;color:var(--amber-deep);margin-bottom:5px;}
  .eco-bau-body{font-size:13px;color:var(--text-sec);line-height:1.65;}
  .eco-bau-body strong{color:var(--text);font-weight:700;}

  /* NHS rebrand */
  body { background: linear-gradient(180deg, var(--nhs-blue) 0%, var(--nhs-dark) 100%) !important; background-attachment: fixed !important; }
  .topnav { box-shadow: 0 2px 14px rgba(0,48,135,0.18); }
  .page { background:#ffffff; border-radius:18px; box-shadow:0 14px 40px rgba(0,48,135,0.20); margin-top:30px !important; margin-bottom:50px !important; }
</style>
