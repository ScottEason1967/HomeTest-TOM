        <div class="stage-image" style="padding:0;border:none;background:none;margin-bottom:22px;"><img src="Assets/Adam Story/adam-stage6.png" alt="Adam Stage 6" style="width:100%;height:auto;border-radius:12px;display:block;box-shadow:0 8px 24px rgba(0,32,64,0.12);"></div>

