  .page{max-width:1180px;margin:0 auto;padding:50px 40px 80px;}
  .header{margin-bottom:42px;}
  .h-eyebrow{display:inline-block;background:var(--accent);color:#fff;font-size:10.5px;font-weight:800;letter-spacing:1.8px;padding:7px 16px;border-radius:4px;text-transform:uppercase;margin-bottom:18px;}
