  .status-banner-h{font-size:11px;font-weight:800;letter-spacing:1.2px;text-transform:uppercase;color:#8D6E1A;margin-bottom:4px;}
  .status-banner-body{font-size:12.5px;color:var(--text-sec);line-height:1.6;}
  .status-banner-body strong{color:var(--text);}
  /* RACI table */
  .raci-section{margin-bottom:48px;}
  .raci-section h2{font-size:22px;font-weight:800;color:var(--nhs-dark);margin-bottom:6px;letter-spacing:-0.2px;}
  .raci-section .raci-sub{font-size:13.5px;color:var(--text-sec);margin-bottom:18px;}
  .raci-table{width:100%;border-collapse:separate;border-spacing:0;background:#fff;border-radius:12px;overflow:hidden;border:1px solid var(--border-lt);box-shadow:0 1px 3px rgba(0,32,64,0.04);}
  .raci-table th{background:var(--accent);color:#fff;font-size:11px;font-weight:800;letter-spacing:1px;text-transform:uppercase;padding:14px 16px;text-align:left;}
