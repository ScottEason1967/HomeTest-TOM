  .raci-table td{padding:14px 16px;border-bottom:1px solid var(--border-lt);font-size:13px;color:var(--text-sec);vertical-align:top;}
  .raci-table td.label{font-weight:700;color:var(--text);width:18%;background:#FAFBFC;}
  .raci-table td.col-r,.raci-table td.col-a,.raci-table td.col-c,.raci-table td.col-i{text-align:center;font-size:11.5px;}
